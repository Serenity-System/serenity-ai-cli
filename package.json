  "description": "CLI for the Serenity AI platform — manage conversations, agents, teams, workspaces and more from the terminal",
  "type": "module",
  "bin": {
    "serenity-ai-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "dev": "bun run src/index.ts"
  },
